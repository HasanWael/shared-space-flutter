rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Check if user is a member of the apartment
    function isApartmentMember(apartmentId) {
      return exists(/databases/$(database)/documents/apartmentMembers/$(apartmentId + '_' + request.auth.uid));
    }

    function isApartmentAdmin(apartmentId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/apartmentMembers/$(apartmentId + '_' + request.auth.uid)) && 
             get(/databases/$(database)/documents/apartmentMembers/$(apartmentId + '_' + request.auth.uid)).data.role == 'admin';
    }

    function isApartmentCreator(apartmentId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/apartments/$(apartmentId)) && 
             get(/databases/$(database)/documents/apartments/$(apartmentId)).data.createdBy == request.auth.uid;
    }

    function isGlobalAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "hwmk2004@gmail.com";
    }

    function isAdmin() {
      return isGlobalAdmin() || 
             (isAuthenticated() && 
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isGlobalAdmin();
    }

    match /apartments/{apartmentId} {
      allow create: if isAuthenticated();
      allow get: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isApartmentMember(apartmentId) || 
        resource.data.createdBy == request.auth.uid || 
        isGlobalAdmin()
      );
      allow list: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isApartmentAdmin(apartmentId) || isGlobalAdmin());
    }

    match /trashHistory/{historyId} {
      allow read: if isAuthenticated() && isApartmentMember(resource.data.apartmentId);
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
    }

    match /inviteCodes/{code} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (isApartmentAdmin(resource.data.apartmentId) || isApartmentCreator(resource.data.apartmentId) || isGlobalAdmin());
    }

    match /apartmentMembers/{memberId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isApartmentMember(resource.data.apartmentId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAway']) ||
        (memberId.matches(".*_" + request.auth.uid) && request.resource.data.role == resource.data.role) ||
        isApartmentAdmin(resource.data.apartmentId) ||
        isApartmentCreator(resource.data.apartmentId) ||
        isGlobalAdmin()
      );
      allow delete: if isAuthenticated() && (
        memberId.matches(".*_" + request.auth.uid) || 
        isApartmentAdmin(resource.data.apartmentId) ||
        isApartmentCreator(resource.data.apartmentId) ||
        isGlobalAdmin()
      );
    }

    match /trashHistory/{historyId} {
      allow read: if isAuthenticated() && isApartmentMember(resource.data.apartmentId);
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
    }

    match /expenses/{expenseId} {
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
      allow read, update, delete: if isAuthenticated() && (isApartmentMember(resource.data.apartmentId) || isApartmentAdmin(resource.data.apartmentId) || isApartmentCreator(resource.data.apartmentId) || isGlobalAdmin());
    }

    match /expenseSplits/{splitId} {
      allow read, write: if isAuthenticated() || isGlobalAdmin();
    }

    match /chores/{choreId} {
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
      allow read, update, delete: if isAuthenticated() && (isApartmentMember(resource.data.apartmentId) || isApartmentAdmin(resource.data.apartmentId) || isApartmentCreator(resource.data.apartmentId) || isGlobalAdmin());
    }

    match /groceries/{groceryId} {
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
      allow read, update, delete: if isAuthenticated() && (isApartmentMember(resource.data.apartmentId) || isApartmentAdmin(resource.data.apartmentId) || isApartmentCreator(resource.data.apartmentId) || isGlobalAdmin());
    }

    match /calendarEvents/{eventId} {
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
      allow read, update, delete: if isAuthenticated() && (isApartmentMember(resource.data.apartmentId) || isApartmentAdmin(resource.data.apartmentId) || isApartmentCreator(resource.data.apartmentId) || isGlobalAdmin());
    }

    match /announcements/{announcementId} {
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
      allow read, update, delete: if isAuthenticated() && (isApartmentMember(resource.data.apartmentId) || isApartmentAdmin(resource.data.apartmentId) || isApartmentCreator(resource.data.apartmentId) || isGlobalAdmin());
    }

    match /showerSlots/{slotId} {
      allow create: if isAuthenticated() && isApartmentMember(request.resource.data.apartmentId);
      allow read, update, delete: if isAuthenticated() && (isApartmentMember(resource.data.apartmentId) || isApartmentAdmin(resource.data.apartmentId) || isApartmentCreator(resource.data.apartmentId) || isGlobalAdmin());
    }
  }
}
